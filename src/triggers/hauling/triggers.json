      }
    ]
  },
  {
    "name": "akaturi_dropoff_success",
    "patterns": [
      {
        "pattern": "^You hand over the package and receive a receipt for it\\.$",
        "type": "regex"
      }
    ]
  },
  {
    "name": "akaturi_job_end_marker",
