        "type": "regex"
      }
    ]
  },
  {
    "name": "akaturi_job_error",
    "patterns": [
      {
        "pattern": "No one here has the faintest idea what you're burbling about!",
        "type": "substring"
      }
    ]
  },
  {
    "name": "akaturi_job_line",
    "patterns": [
      {
        "pattern": "^.+",
        "type": "regex"
      }
    ]
  },
  {
    "name": "akaturi_job_start",
    "patterns": [
      {
        "pattern": "^Your task is to pick up a package on",
