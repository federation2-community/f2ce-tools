      {
        "pattern": "^Couldn't find any job in the Sol cartel with number (\\d+)\\. Either there is no job with that number or someone else has taken it\\.$",
        "type": "regex"
      }
    ]
  },
  {
    "name": "ac_loan_repaid",
    "patterns": [
      {
        "pattern": "Your loan has been cleared!",
        "type": "substring"
      }
    ]
  },
  {
    "name": "ac_work_line",
    "patterns": [
      {
        "pattern": "^\\s+\\d+\\.\\s+From\\s+.+\\s+to\\s+.+\\s+\\-\\s+\\d+\\s+tons of\\s+.+\\s+\\-\\s+\\d+gtu\\s+\\d+ig/tn\\s+\\d+hcr",
        "type": "regex"
      }
    ]
  },
  {
    "name": "ac_work_start",
    "patterns": [
      {
        "pattern": "^Work available from Armstrong Cuthbert:$",
        "type": "regex"
      }
    ]
  },
  {
    "name": "akaturi_dropoff_error",
    "patterns": [
      {
        "pattern": "There's no one here expecting anything from you\\.",
