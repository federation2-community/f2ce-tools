[
  {
    "name": "game_shutdown_warning",
    "patterns": [
      {
        "pattern": "^Federation II will be closing down for a short while in six minutes time\\.$",
        "type": "regex"
      }
    ]
  },
  {
    "name": "ac_collect_errors",
    "patterns": [
      {
        "pattern": "^You (?:have already collected your cargo|don't have a job to collect)!$",
        "type": "regex"
      }
    ]
  },
  {
    "name": "ac_collect_success",
    "patterns": [
      {
        "pattern": "The clerk plugs your com unit into a terminal",
        "type": "substring"
      }
    ]
  },
  {
    "name": "ac_deliver_capture_payment",
    "patterns": [
      {
        "pattern": "([\\d,]+)ig",
        "type": "regex"
      }
    ]
  },
  {
    "name": "ac_deliver_error",
    "patterns": [
      {
        "pattern": "^You don't have a cargo to deliver",
        "type": "regex"
      }
    ]
  },
  {
    "name": "ac_deliver_success",
    "patterns": [
      {
        "pattern": "has been transferred to your account",
        "type": "substring"
      }
    ]
  },
  {
    "name": "ac_deliver_waiting",
    "patterns": [
      {
        "pattern": "there are no stevedores available to unload your ship",
        "type": "substring"
      }
    ]
