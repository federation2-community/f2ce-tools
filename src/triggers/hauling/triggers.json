      }
    ]
  },
  {
    "name": "akaturi_pickup_line",
    "patterns": [
      {
        "pattern": "^.+",
        "type": "regex"
      }
    ]
  },
  {
    "name": "akaturi_pickup_success",
    "patterns": [
      {
        "pattern": "^You pickup the valuable package and sign for it\\.$",
        "type": "regex"
      }
    ]
  },
  {
    "name": "daily_limit_error",
    "patterns": [
      {
        "pattern": "^Your order is rejected, since you have exceeded the daily gross income limit for commodity trading!$",
